# Copy this file to .env and replace every value marked as required.
# Never commit .env.

# Docker image published for production.
APP_IMAGE=your-registry/quick_presence:latest

# Public domain without protocol or trailing slash.
APP_DOMAIN=quickpresence.xyz

# Absolute host directory for SQLite databases and Active Storage uploads.
APP_STORAGE_PATH=/var/lib/quick_presence/storage

# Absolute host directories used by Caddy to persist certificates and state.
CADDY_DATA_PATH=/var/lib/quick_presence/caddy/data
CADDY_CONFIG_PATH=/var/lib/quick_presence/caddy/config

# Rails credentials encryption key (required, generated locally).
RAILS_MASTER_KEY=replace-with-your-rails-master-key
