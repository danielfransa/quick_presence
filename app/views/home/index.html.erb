<section class="row justify-content-center">
  <div class="col-lg-9 col-xl-8">
    <div class="p-4 p-md-5 bg-white border rounded-3 shadow-sm">
      <span class="badge text-bg-primary mb-3"><%= t(".badge") %></span>
      <h1 class="display-5 fw-bold text-body-emphasis"><%= t(".title") %></h1>
      <p class="lead text-secondary mt-3"><%= t(".description") %></p>

      <div class="d-flex flex-wrap gap-2 mt-4">
        <%= link_to t(".create_account"), new_user_registration_path, class: "btn btn-primary btn-lg" %>
        <%= link_to t(".sign_in"), new_user_session_path, class: "btn btn-outline-secondary btn-lg" %>
      </div>
    </div>

    <div class="row g-3 mt-3">
      <div class="col-md-4">
        <div class="h-100 p-3 bg-white border rounded-3">
          <h2 class="h6 fw-bold"><%= t(".features.custom_fields.title") %></h2>
          <p class="mb-0 text-secondary"><%= t(".features.custom_fields.description") %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="h-100 p-3 bg-white border rounded-3">
          <h2 class="h6 fw-bold"><%= t(".features.qr_sharing.title") %></h2>
          <p class="mb-0 text-secondary"><%= t(".features.qr_sharing.description") %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="h-100 p-3 bg-white border rounded-3">
          <h2 class="h6 fw-bold"><%= t(".features.csv_export.title") %></h2>
          <p class="mb-0 text-secondary"><%= t(".features.csv_export.description") %></p>
        </div>
      </div>
    </div>
  </div>
</section>
