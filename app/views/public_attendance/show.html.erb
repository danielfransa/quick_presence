<section class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5">
        <span class="badge text-bg-success mb-3">Open for responses</span>
        <h1 class="h2 fw-bold"><%= @attendance_list.title %></h1>
        <% if @attendance_list.description.present? %>
          <p class="text-secondary mt-2"><%= @attendance_list.description %></p>
        <% end %>

        <div class="alert alert-info mt-4" role="alert">
          The information you submit will be used only for this attendance list.
        </div>

        <%= form_with url: public_attendance_path(@attendance_list.public_token), method: :post, class: "mt-4" do %>
          <% if @attendance_response.errors.any? %>
            <div class="alert alert-danger" role="alert">
              <p class="fw-semibold mb-0"><%= pluralize(@attendance_response.errors.count, "error") %> prevented your attendance from being recorded.</p>
            </div>
          <% end %>

          <% @attendance_list.attendance_fields.ordered.each do |field| %>
            <div class="mb-3">
              <%= label_tag "answers_#{field.id}", field.label, class: "form-label" %>
              <%= text_field_tag "answers[#{field.id}]", params.dig(:answers, field.id.to_s), required: field.required?, class: "form-control" %>
            </div>
          <% end %>

          <%= submit_tag "Submit attendance", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</section>
