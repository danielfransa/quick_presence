<section>
  <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
      <h1 class="h2 fw-bold mb-1"><%= t(".title") %></h1>
      <p class="text-secondary mb-0"><%= t(".description") %></p>
    </div>

    <div>
      <%= link_to t(".new_list"), new_attendance_list_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if @attendance_lists.any? %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th><%= t(".table.title") %></th>
              <th><%= t(".table.status") %></th>
              <th><%= t(".table.responses") %></th>
              <th class="text-end"><%= t(".table.actions") %></th>
            </tr>
          </thead>
          <tbody>
            <% @attendance_lists.each do |attendance_list| %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= attendance_list.title %></div>
                  <div class="small text-secondary"><%= l(attendance_list.created_at.to_date, format: :long) %></div>
                </td>
                <td>
                  <% if attendance_list.open? %>
                    <span class="badge text-bg-success"><%= t("common.status.open") %></span>
                  <% else %>
                    <span class="badge text-bg-secondary"><%= t("common.status.closed") %></span>
                  <% end %>
                </td>
                <td><%= attendance_list.attendance_responses_count %></td>
                <td class="text-end">
                  <%= link_to t("common.actions.open"), attendance_list, class: "btn btn-outline-primary btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="p-5 bg-white border rounded-3 text-center shadow-sm">
      <h2 class="h4"><%= t(".empty.title") %></h2>
      <p class="text-secondary"><%= t(".empty.description") %></p>
      <%= link_to t(".empty.action"), new_attendance_list_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</section>
