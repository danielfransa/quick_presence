<section>
  <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
      <h1 class="h2 fw-bold mb-1">Attendance lists</h1>
      <p class="text-secondary mb-0">Manage your temporary attendance forms.</p>
    </div>

    <div>
      <%= link_to "New list", new_attendance_list_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if @attendance_lists.any? %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Responses</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @attendance_lists.each do |attendance_list| %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= attendance_list.title %></div>
                  <div class="small text-secondary"><%= attendance_list.created_at.to_date.to_fs(:long) %></div>
                </td>
                <td>
                  <% if attendance_list.open? %>
                    <span class="badge text-bg-success">Open</span>
                  <% else %>
                    <span class="badge text-bg-secondary">Closed</span>
                  <% end %>
                </td>
                <td><%= attendance_list.attendance_responses.count %></td>
                <td class="text-end">
                  <%= link_to "Open", attendance_list, class: "btn btn-outline-primary btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="p-5 bg-white border rounded-3 text-center shadow-sm">
      <h2 class="h4">No attendance lists yet</h2>
      <p class="text-secondary">Create your first public attendance form and share it by QR code.</p>
      <%= link_to "Create your first list", new_attendance_list_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</section>
