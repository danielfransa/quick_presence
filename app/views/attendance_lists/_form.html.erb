<%= form_with model: attendance_list do |form| %>
  <% if attendance_list.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <p class="fw-semibold mb-2"><%= pluralize(attendance_list.errors.count, "error") %> prevented this list from being saved.</p>
      <ul class="mb-0">
        <% attendance_list.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
      <h2 class="h5 mb-0">List details</h2>
    </div>
    <div class="card-body">
      <div class="mb-3">
        <%= form.label :title, class: "form-label" %>
        <%= form.text_field :title, required: true, class: "form-control", placeholder: "Database class" %>
      </div>

      <div class="mb-3">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, rows: 4, class: "form-control", placeholder: "Short instructions for participants" %>
      </div>

      <div class="mb-3">
        <%= form.hidden_field :time_zone, value: attendance_list.time_zone, data: { time_zone_field: true } %>
        <div class="alert alert-light border mb-0" role="status">
          <div class="fw-semibold">Time zone detected automatically</div>
          <div class="small text-secondary">
            Dates and times below will be interpreted as <span data-time-zone-label><%= attendance_list.time_zone %></span>.
          </div>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <%= form.label :starts_at_local, "Starts at", class: "form-label" %>
          <%= form.datetime_field :starts_at_local, value: attendance_list.starts_at_local, class: "form-control" %>
        </div>

        <div class="col-md-6">
          <%= form.label :ends_at_local, "Ends at", class: "form-label" %>
          <%= form.datetime_field :ends_at_local, value: attendance_list.ends_at_local, required: true, class: "form-control" %>
          <div class="form-text">Required so responses can be deleted 48 hours later.</div>
        </div>
      </div>

      <div class="form-check form-switch mt-3">
        <%= form.check_box :active, class: "form-check-input" %>
        <%= form.label :active, "Accept responses", class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white d-flex flex-column flex-md-row justify-content-between gap-2">
      <div>
        <h2 class="h5 mb-1">Custom fields</h2>
        <p class="mb-0 text-secondary small">
          Add up to 5 participant fields. Blank field names are ignored.
        </p>
      </div>
      <span class="badge text-bg-light align-self-md-start">Timestamp is automatic</span>
    </div>
    <div class="card-body">
      <p class="text-secondary small">
        The submission timestamp is recorded automatically and does not count as one of the 5 custom fields.
      </p>

      <div class="vstack gap-3">
        <%= form.fields_for :attendance_fields do |field_form| %>
          <div class="border rounded-3 p-3 bg-light">
            <div class="row g-3 align-items-end">
              <div class="col-md-8">
                <%= field_form.label :label, "Field #{field_form.index.to_i + 1}", class: "form-label" %>
                <%= field_form.text_field :label, class: "form-control", placeholder: "Name, Student code, Class..." %>
                <%= field_form.hidden_field :field_type, value: "text" %>
                <%= field_form.hidden_field :position, value: field_form.index.to_i %>
              </div>

              <div class="col-md-4">
                <div class="form-check">
                  <%= field_form.check_box :required, checked: field_form.object.required.nil? ? true : field_form.object.required, class: "form-check-input" %>
                  <%= field_form.label :required, "Required", class: "form-check-label" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <%= form.submit "Save attendance list", class: "btn btn-primary" %>
    <%= link_to "Cancel", attendance_lists_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
  (() => {
    const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const field = document.querySelector("[data-time-zone-field]");
    const label = document.querySelector("[data-time-zone-label]");

    if (!timeZone || !field) return;

    field.value = timeZone;

    if (label) label.textContent = timeZone;
  })();
</script>
