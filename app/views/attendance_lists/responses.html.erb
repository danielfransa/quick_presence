<section>
  <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
      <h1 class="h2 fw-bold mb-1">Responses</h1>
      <p class="text-secondary mb-0"><%= @attendance_list.title %></p>
      <% if @attendance_list.responses_retention_expires_at.present? %>
        <p class="text-secondary small mb-0">
          Available until <%= l(@attendance_list.local_time(@attendance_list.responses_retention_expires_at), format: :long) %>
          (<%= @attendance_list.time_zone %>).
        </p>
      <% end %>
    </div>

    <div class="d-flex flex-wrap gap-2 align-self-md-start">
      <%= link_to "Export CSV", export_attendance_list_path(@attendance_list, format: :csv), class: "btn btn-outline-primary" %>
      <%= link_to "Export Excel", export_attendance_list_path(@attendance_list, format: :xlsx), class: "btn btn-primary" %>
      <%= link_to "Back", @attendance_list, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <% if @responses.any? %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Timestamp</th>
              <% @attendance_list.attendance_fields.ordered.each do |field| %>
                <th><%= field.label %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @responses.each do |response| %>
              <% answers_by_field_id = response.attendance_answers.index_by(&:attendance_field_id) %>
              <tr>
                <td class="text-nowrap text-secondary"><%= l(response.submitted_at, format: :long) %></td>
                <% @attendance_list.attendance_fields.ordered.each do |field| %>
                  <td><%= answers_by_field_id[field.id]&.value %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="p-5 bg-white border rounded-3 text-center shadow-sm">
      <h2 class="h4">No responses yet</h2>
      <p class="text-secondary mb-0">Share the public link or QR code to start collecting attendance.</p>
    </div>
  <% end %>
</section>
