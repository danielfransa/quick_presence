<section class="row justify-content-center">
  <div class="col-md-8 col-lg-6 col-xl-5">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5">
        <span class="badge text-bg-primary mb-3">QuickPresence</span>
        <h1 class="h2 fw-bold">Reset your password</h1>
        <p class="text-secondary">Enter your email and we will send password reset instructions.</p>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-4" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-4">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "you@example.com" %>
          </div>

          <%= f.submit "Send reset instructions", class: "btn btn-primary w-100" %>
        <% end %>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
