<section class="row justify-content-center">
  <div class="col-lg-8">
    <div class="mb-4">
      <h1 class="h2 fw-bold mb-1">Account settings</h1>
      <p class="text-secondary mb-0">Review your account and deletion options.</p>
    </div>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <dl class="row mb-0">
          <dt class="col-sm-3">Username</dt>
          <dd class="col-sm-9"><%= resource.username %></dd>
        </dl>

        <div class="alert alert-warning mt-4 mb-0" role="alert">
          Password recovery and password changes are not available in this version. Keep your password stored safely.
        </div>

        <div class="mt-4">
          <%= link_to "Back", attendance_lists_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>

    <div class="card border-danger shadow-sm">
      <div class="card-body">
        <h2 class="h5 text-danger">Delete account</h2>
        <p class="text-secondary">This permanently removes your account and attendance lists.</p>
        <%= button_to "Delete my account",
          registration_path(resource_name),
          data: { turbo_confirm: "Are you sure?" },
          method: :delete,
          class: "btn btn-outline-danger" %>
      </div>
    </div>
  </div>
</section>
