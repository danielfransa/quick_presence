<section class="row justify-content-center">
  <div class="col-md-8 col-lg-6 col-xl-5">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5">
        <span class="badge text-bg-primary mb-3">QuickPresence</span>
        <h1 class="h2 fw-bold">Sign in</h1>
        <p class="text-secondary">Access your attendance lists and submitted responses.</p>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-4" }) do |f| %>
          <div class="mb-3">
            <%= f.label :username, class: "form-label" %>
            <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "form-control", placeholder: "organizer_name" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-check mb-4">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, class: "form-check-label" %>
            </div>
          <% end %>

          <%= f.submit "Sign in", class: "btn btn-primary w-100" %>
        <% end %>

        <div class="alert alert-warning mt-4 mb-0" role="alert">
          Password recovery is not available. Keep your password stored safely.
        </div>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
