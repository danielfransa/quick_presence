<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "QuickPresence" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="QuickPresence">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
      <div class="container">
        <%= link_to "QuickPresence", user_signed_in? ? attendance_lists_path : root_path, class: "navbar-brand fw-bold" %>

        <div class="d-flex flex-wrap align-items-center gap-3 ms-auto">
          <ul class="navbar-nav flex-row flex-wrap gap-2">
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to "Attendance Lists", attendance_lists_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "New list", new_attendance_list_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Account settings", edit_user_registration_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>

          <div class="d-flex flex-wrap align-items-center gap-2">
            <% if user_signed_in? %>
              <span class="navbar-text small text-muted"><%= current_user.username %></span>
              <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-outline-secondary btn-sm" %>
              <%= link_to "Sign up", new_user_registration_path, class: "btn btn-primary btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="container py-4 py-lg-5">
      <% if notice.present? %>
        <div class="alert alert-success" role="alert"><%= notice %></div>
      <% end %>

      <% if alert.present? %>
        <div class="alert alert-danger" role="alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
